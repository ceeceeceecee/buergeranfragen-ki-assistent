# IMAP- und SMTP-Konfiguration
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=buergeranfragen@example.de
IMAP_PASSWORD=IhrIMAPPasswort
IMAP_FOLDER=INBOX

# SMTP-Konfiguration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=buergeranfragen@example.de
SMTP_PASSWORD=IhrSMTPPasswort
SMTP_FROM=Buergeranfragen <buergeranfragen@example.de>

# KI-Konfiguration
OPENAI_API_KEY=sk-IhrOpenAI-API-Key
# Alternativ: Ollama lokal
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3

# Behörden-Konfiguration
BEHOERDENNAME=Stadt Musterhausen
BEHOERDENLOGO_URL=https://example.com/wappen.png

# PostgreSQL (Audit-Log)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=buergeranfragen_audit
POSTGRES_USER=audit_user
POSTGRES_PASSWORD=IhrDatenbankPasswort

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=IhrN8NPasswort

# Zeitzone
TZ=Europe/Berlin
