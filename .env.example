# Bürgeranfragen-KI-Assistent — Konfiguration
# Kopieren Sie diese Datei als .env und passen Sie die Werte an.

# --- Ollama ---
OLLAMA_MODEL=llama3.1
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434

# --- n8n ---
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=false
N8N_ENCRYPTION_KEY=  # Wird automatisch generiert

# --- PostgreSQL ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=  # Wird automatisch generiert
POSTGRES_PORT=5432

# --- Open WebUI ---
WEBUI_ENABLED=true
WEBUI_PORT=3000

# --- E-Mail (IMAP) ---
IMAP_SERVER=imap.beispiel.de
IMAP_PORT=993
IMAP_USER=buergeranfragen@beispiel.de
IMAP_PASSWORD=

# --- E-Mail (SMTP) ---
SMTP_SERVER=smtp.beispiel.de
SMTP_PORT=587
SMTP_USER=buergeranfragen@beispiel.de
SMTP_PASSWORD=
EMAIL_FROM=buergeranfragen@beispiel.de
